{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nicks-nook.local/schemas/dependency-graph.schema.json",
  "title": "vault dependency graph",
  "type": "object",
  "required": ["version", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "version": {"const": 1},
    "generated_at": {"type": "string", "format": "date"},
    "nodes": {"type": "array", "items": {"$ref": "#/$defs/node"}},
    "edges": {"type": "array", "items": {"$ref": "#/$defs/edge"}}
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "kind": {"enum": ["source", "wiki_page", "entity"]},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "edge": {
      "type": "object",
      "required": ["from", "to", "type", "evidence"],
      "additionalProperties": false,
      "properties": {
        "from": {"type": "string", "minLength": 1},
        "to": {"type": "string", "minLength": 1},
        "type": {"enum": ["references", "links_to", "mentions", "alias_of", "candidate_for_review"]},
        "evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^(Data|Level Knowledge)/.+"}}
      }
    }
  }
}
